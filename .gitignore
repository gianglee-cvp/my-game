# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]serSettings/

# Memory dumps
*.lldmp

# Exported Visual Studio Project solutions
*.sln
*.csproj
*.unityproj
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file companion meta files
*.phaser.meta

# Compilation Inventories
Assets/UnityTestTools/
Assets/UnityTestTools.meta

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated JetBrains Rider SDKs
.idea/

# Windows design file caches
Thumbs.db
ehthumbs.db

# Mac design file caches
.DS_Store

# Android Studio project files
*.iml
.navigation/

# Crashlytics config (Auto-generated)
crashlytics-build.properties

# Packed packages
*.unitypackage

# Temporary files created by Unity Editor
Assets/[Tt]emp/
Assets/[Tt]emp.meta

# Unity Editor persistent data
/Assets/Editor/Data/

# Project configuration folders
.vscode/
.plastic/

# Recovery from crashes
Assets/_Recovery
Assets/_Recovery.meta

.worktrees/
